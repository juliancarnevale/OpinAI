# ============================================================================
# OpinAI Environment Variables Template
# Copy this file to a new file named '.env' in the root directory and fill in your values.
# ============================================================================

# Google Gemini AI API Key (required for feedback processing)
# Get a key from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# JWT Signing Key (required for user authentication security)
# Must be a secure random hex string of at least 32 characters (256 bits)
JWT_SECRET=your_jwt_secret_of_at_least_32_characters_here

# Backend REST API endpoint URL for the React frontend client
VITE_API_URL=http://localhost:8080/api/v1
